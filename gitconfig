[color]
  ui = true
[core]
  excludesfile = ~/.gitignore.global
[user]
# fill this in during first run of `git` and then get rid of these
# TODO: prompt in install script
# name = Chris Dillon
# email = squarism@gmail.com
[credential]
  helper = osxkeychain

[merge]
  conflictstyle = diff3

# difftastic
[diff]
  external = difft

[commit]
  verbose = true

[branch]
  autosetupmerge = always
[alias]
  co = checkout
  b = branch

# this will slowly become the default anyway
[init]
  defaultBranch = main
